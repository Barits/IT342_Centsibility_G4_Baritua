# Database Configuration
# For Supabase: Get these from Project Settings -> Database
# Use Session Pooler URL for IPv4 compatibility
DB_URL=jdbc:postgresql://aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
DB_USERNAME=postgres.cxobyzyvsmqbmousypvx
DB_PASSWORD=your_database_password_here

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
# Generate a secure random string for production (min 64 characters)
JWT_SECRET=centsibilitySecretKeyForJWTAuthenticationThatIsLongEnough123456789
JWT_EXPIRATION=86400000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here

# Logging (optional)
LOG_LEVEL=DEBUG
SECURITY_LOG_LEVEL=DEBUG
DB_SHOW_SQL=true

# Connection Pool (optional - defaults shown)
HIKARI_MAX_POOL=5
HIKARI_MIN_IDLE=2
HIKARI_CONN_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000
